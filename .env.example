# SpendScope Configuration
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
API_HOST=127.0.0.1
API_PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://spendscope:spendscope_dev@localhost:5432/spendscope

# Auth
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# AI Coach (Anthropic Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Plaid bank sync (Phase 9)
# Get credentials at https://dashboard.plaid.com/team/keys
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Webhook URL: leave blank for local dev, set to your public URL in prod
PLAID_WEBHOOK_URL=
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PLAID_TOKEN_ENCRYPTION_KEY=
